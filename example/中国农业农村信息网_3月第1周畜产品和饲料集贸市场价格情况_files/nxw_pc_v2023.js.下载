				$(".content_body_box p font").css("font-size", "16px").css("line-height", "32px");
		$(".content_body_box div").css("font-size", "16px").css("line-height", "32px");
		$(".content_body_box div span").css("font-size", "16px").css("line-height", "32px");
		$(".content_body_box p span").css("font-size", "16px").css("line-height", "32px");
		$(".content_body_box .tit_p").css("font-size", "18px").css("line-height", "36px");
		$(this).addClass('active').siblings().removeClass('active');
	});
	$(".f18").click(function () {
		$(".content_body_box ").css("font-size", "18px").css("line-height", "36px");
		$(".content_body_box p").css("font-size", "18px").css("line-height", "36px");
				$(".content_body_box p font").css("font-size", "18px").css("line-height", "36px");
		$(".content_body_box div").css("font-size", "18px").css("line-height", "36px");
		$(".content_body_box div span").css("font-size", "18px").css("line-height", "36px");
		$(".content_body_box p span").css("font-size", "18px").css("line-height", "36px");
		$(".content_body_box .tit_p").css("font-size", "20px").css("line-height", "40px");
		$(this).addClass('active').siblings().removeClass('active');
	});
	$(".f20").click(function () {
		$(".content_body_box ").css("font-size", "20px").css("line-height", "40px");
		$(".content_body_box p").css("font-size", "20px").css("line-height", "40px");
				$(".content_body_box p font").css("font-size", "20px").css("line-height", "40px");
		$(".content_body_box div").css("font-size", "20px").css("line-height", "40px");
		$(".content_body_box div span").css("font-size", "20px").css("line-height", "40px");
		$(".content_body_box p span").css("font-size", "20px").css("line-height", "40px");
		$(".content_body_box .tit_p").css("font-size", "22px").css("line-height", "44px");
		$(this).addClass('active').siblings().removeClass('active');
	});
	$(".f22").click(function () {
		$(".content_body_box ").css("font-size", "22px").css("line-height", "44px");
		$(".content_body_box p").css("font-size", "22px").css("line-height", "44px");
				$(".content_body_box p font").css("font-size", "22px").css("line-height", "44px");
		$(".content_body_box div").css("font-size", "22px").css("line-height", "44px");
		$(".content_body_box div span").css("font-size", "22px").css("line-height", "44px");
		$(".content_body_box p span").css("font-size", "22px").css("line-height", "44px");
		$(".content_body_box .tit_p").css("font-size", "24px").css("line-height", "48px");
		$(this).addClass('active').siblings().removeClass('active');
	});

	//农业品种
	$(".breed_hearder_right ul li").hover(function () {
		$(this).addClass("active").siblings().removeClass("active")
		var i = $(this).index();
		$(".breed_hearder_right .more").eq(i).addClass("active").siblings(".breed_hearder_right .more").removeClass("active");
		$(".breed_list").eq(i).addClass("selected").siblings(".breed_list").removeClass("selected");
	})


	//科技推广
	$(".guidance_tit_text ul li").hover(function () {
		$(this).addClass("active").siblings().removeClass("active")
		var i = $(this).index();
		$(".guidance_tit .more").eq(i).addClass("active").siblings(".guidance_tit .more").removeClass("active");
		$(".guidance_list ul").eq(i).addClass("selected").siblings(".guidance_list ul").removeClass("selected");
	})

	
	//农业品种
	$(".detection_hearder_right ul li").hover(function () {
		$(this).addClass("active").siblings().removeClass("active")
		var i = $(this).index();
		$(".detection_hearder_right .more").eq(i).addClass("active").siblings(".detection_hearder_right .more").removeClass("active");
		$(".detection_list").eq(i).addClass("selected").siblings(".detection_list").removeClass("selected");
	})
	
	// 生产
	var sc_mySwiper = new Swiper('.sc_main_nypz_js',{
		loop:true,
		grabCursor: true,
		slidesPerView: 9,
	})
	$('.sc_main_prev').on('click', function(e){
		e.preventDefault()
		sc_mySwiper.swipePrev()
	})
	$('.sc_main_next').on('click', function(e){
		e.preventDefault()
		sc_mySwiper.swipeNext()
	})


		//数据-供需形势
		$(".supply_ul li").hover(function () {
			$(this).addClass("active").siblings().removeClass("active")
			var i = $(this).index();
			$(".trends_tit_supply .more").eq(i).addClass("active").siblings(".trends_tit_supply .more").removeClass("active");
			$(".trends_list_supply ul").eq(i).addClass("selected").siblings(".trends_list_supply ul").removeClass("selected");
		})
})

