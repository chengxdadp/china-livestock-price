$(function () {
	// 轮播
	var bannerswiper = new Swiper('.swiper_video', {
		// paginationClickable :true,
		slidesPerView: 3,
		loop: true,
		autoplay: false,
		// autoplayDisableOnInteraction:false,
		// speed:500,
		// resizeReInit : true,
		observer: true,//修改swiper自己或子元素时，自动初始化swiper
		observeParents: true,//修改swiper的父元素时，自动初始化swiper
		
		//默认字号
	})
	$('.swiper_video .arrow-left').on('click', function (e) {
		e.preventDefault()
		bannerswiper.swipePrev()
	})
	$('.swiper_video .arrow-right').on('click', function (e) {
		e.preventDefault()
		bannerswiper.swipeNext()
	})

	//手风琴
	$(".sfq-slide-con .slide-item").on("click", function () {
		$(this).addClass("on").siblings().removeClass("on");
	});

	// 致富天地
	$(".rich_nav ul li").hover(function () {
		$(this).addClass("active").siblings().removeClass("active")
		var i = $(this).index();
		$(".rich_cont_wrap .rich_cont").eq(i).addClass("selected").siblings().removeClass("selected")
	})
	// 农业课堂
	$(".agricul_list1 .agricul_com").on("click", function () {
		$(this).addClass("on").siblings().removeClass("on");
	});
	// 气象农业
	$(".agricul_list2 .agricul_com").on("click", function () {
		$(this).addClass("on").siblings().removeClass("on");
	});

	//专家团队
	$(".expert_title_list ul li").hover(function () {
		$(this).addClass("active").siblings().removeClass("active")
		var i = $(this).index();
		$(".expert_title_list .more").eq(i).addClass("active").siblings(".expert_title_list .more").removeClass("active");
		$(".expert_lists_wrap .expert_lists").eq(i).addClass("selected").siblings().removeClass("selected")
	})


	// 生产轮播
	var newsswiper = new Swiper('.trends_swiper', {
		slidesPerView: 1,
		loop: true,
		autoplay: 6000,
		autoplayDisableOnInteraction: false,
		speed: 500,
		resizeReInit: true,
		paginationClickable: true,
		observer: true,//修改swiper自己或子元素时，自动初始化swiper
		observeParents: true,//修改swiper的父元素时，自动初始化swiper
		onSwiperCreated: function (swiper) {
			$('.trends_left .pageState').html("<span class='t1'>" + (swiper.activeLoopIndex + 1) + "</span>/<span class='t2'>" + (swiper.slidesGrid.length - 2) + "</span>");
		},
		onSlideChangeStart: function (swiper) {
			$('.trends_left .pageState').html("<span class='t1'>" + (swiper.activeLoopIndex + 1) + "</span>/<span class='t2'>" + (swiper.slidesGrid.length - 2) + "</span>");
		}
	})
	$('.trends_left .arrow-left').on('click', function (e) {
		e.preventDefault()
		newsswiper.swipePrev()
	})
	$('.trends_left .arrow-right').on('click', function (e) {
		e.preventDefault()
		newsswiper.swipeNext()
	})
	$('.trends_swiper').hover(function () {
		newsswiper.stopAutoplay();
	}, function () {
		newsswiper.startAutoplay();
	});


	// 视频详情页字体大小调整


	
	$(".f16").click(function () {
		$(".content_body_box ").css("font-size", "16px").css("line-height", "32px");
